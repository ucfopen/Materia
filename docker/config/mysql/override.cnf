[mysqld]
# Make InnoDB buffer pool as large as possible while considering other memory usage on machine
# innodb_buffer_pool_size must be a multiple of 128M
innodb_buffer_pool_size = 4096M
# Adjust redo logging for heavy write workload
innodb_redo_log_capacity = 2048M
innodb_log_buffer_size = 256M
max_allowed_packet=64M
sql_mode = "STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION"
default_authentication_plugin=mysql_native_password
